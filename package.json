{
  "name": "xlsx-template-engine",
  "version": "1.0.0",
  "description": "Server-side TypeScript report engine for generating .xlsx files",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:tests": "tsc --ignoreConfig --noEmit --target ES2020 --module CommonJS --strict --noUncheckedIndexedAccess --exactOptionalPropertyTypes false --esModuleInterop --skipLibCheck --types node tests/workbook-type-safety.test.ts",
    "test": "tsx tests/run.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": {
    "name": "Nguyễn Văn Việt",
    "email": "nguyenvanviet.150204@gmail.com",
    "url": "https://vittapcode.id.vn"
  },
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "exceljs": "^4.4.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
